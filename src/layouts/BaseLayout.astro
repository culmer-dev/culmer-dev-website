---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  active?: "home" | "blog";
  showFooter?: boolean;
}

const {
  title,
  description = "Colin Ulmer — software engineer writing about distributed systems and databases.",
  active,
  showFooter = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {/* Set theme before paint to avoid a flash of the wrong palette */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t !== "dark" && t !== "light") t = "light";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <Nav active={active} />
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var btn = document.getElementById("theme-toggle");
        var label = document.querySelector("[data-theme-label]");

        function render(theme) {
          if (label) label.textContent = theme === "dark" ? "◐ dark" : "◑ light";
        }
        render(root.getAttribute("data-theme") || "light");

        if (btn) {
          btn.addEventListener("click", function () {
            var next =
              root.getAttribute("data-theme") === "dark" ? "light" : "dark";
            root.setAttribute("data-theme", next);
            try {
              localStorage.setItem("theme", next);
            } catch (e) {}
            render(next);
          });
        }
      })();
    </script>
  </body>
</html>
