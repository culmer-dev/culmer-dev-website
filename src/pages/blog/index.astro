---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="blog — culmer.dev" active="blog">
  <section class="blog">
    <div class="blog__cmd"><span style="color: var(--accent)">$</span> ls -la ./blog</div>
    <h1 class="blog__title">./blog</h1>
<!--
    <p class="blog__intro">
      Field notes on storage systems and experiments
    </p>
-->

    {
      posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <span class="tag">{post.data.tag}</span>
            <span>{post.data.date}</span>
            <span>·</span>
            <span>{post.data.read} read</span>
          </div>
          <h2 class="post-card__title">{post.data.title}</h2>
          <p class="post-card__excerpt">{post.data.excerpt}</p>
        </a>
      ))
    }
  </section>
</BaseLayout>
