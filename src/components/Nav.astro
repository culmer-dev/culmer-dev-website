---
interface Props {
  active?: "home" | "blog";
}
const { active } = Astro.props;
---

<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="brand" aria-label="culmer.dev home">
      <span class="brand__tilde">~/</span>culmer<span class="brand__dev">.dev</span>
    </a>
    <div class="nav__links">
      <a
        href="/"
        class="nav__link"
        aria-current={active === "home" ? "page" : undefined}>home</a
      >
      <a
        href="/blog"
        class="nav__link"
        aria-current={active === "blog" ? "page" : undefined}>blog</a
      >
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
      >
        <span data-theme-label>◑ light</span>
      </button>
    </div>
  </div>
</nav>
